<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ЭхоКГ Калькулятор</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d1117; --surface: #161b22; --surface2: #1c2128;
  --border: #30363d; --accent: #58a6ff; --warn: #f0883e;
  --danger: #f85149; --text: #e6edf3; --text2: #8b949e;
  --text3: #6e7681; --input-bg: #0d1117;
  --normal: #3fb950; --abnormal: #f0883e;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'IBM Plex Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; padding: 0 0 60px; }
header {
  background: var(--surface); border-bottom: 1px solid var(--border);
  padding: 16px 24px; display: flex; align-items: center; gap: 16px;
  position: sticky; top: 0; z-index: 100;
}
.logo {
  width: 38px; height: 38px;
  background: linear-gradient(135deg, #1c6ef3, #58a6ff);
  border-radius: 10px; display: flex; align-items: center; justify-content: center;
  font-family: 'IBM Plex Mono', monospace; font-weight: 600; font-size: 14px; color: #fff; flex-shrink: 0;
}
header h1 { font-size: 18px; font-weight: 600; }
header span { font-size: 13px; color: var(--text2); font-weight: 300; }
.hint { margin-left: auto; display: flex; gap: 16px; align-items: center; font-size: 12px; color: var(--text2); }
.hint-dot { display: flex; align-items: center; gap: 5px; }
.dot { width: 8px; height: 8px; border-radius: 50%; }
.offline-badge {
  display: none; background: var(--warn); color: #0d1117;
  font-size: 11px; font-weight: 600; padding: 2px 8px; border-radius: 4px; margin-left: 8px;
}
/* Patients bar */
.patients-bar {
  background: var(--surface2); border-bottom: 1px solid var(--border);
  padding: 10px 24px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
}
.patients-bar-label { font-size: 12px; color: var(--text2); font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; flex-shrink: 0; }
.patients-list { display: flex; gap: 6px; flex-wrap: wrap; flex: 1; min-height: 28px; align-items: center; }
.patient-chip {
  background: var(--surface); border: 1px solid var(--border); border-radius: 20px;
  padding: 4px 12px; font-size: 12px; color: var(--text2); cursor: pointer;
  display: flex; align-items: center; gap: 6px; transition: all 0.15s;
}
.patient-chip:hover { border-color: var(--accent); color: var(--text); }
.patient-chip.active { border-color: var(--accent); color: var(--accent); background: rgba(88,166,255,0.08); }
.patient-chip-del { color: var(--text3); font-size: 16px; line-height: 1; cursor: pointer; padding: 0 2px; }
.patient-chip-del:hover { color: var(--danger); }
.patients-actions { display: flex; gap: 6px; flex-shrink: 0; }
.main { max-width: 900px; margin: 32px auto; padding: 0 24px; display: flex; flex-direction: column; gap: 20px; }
.section { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.section-header { background: var(--surface2); padding: 12px 20px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid var(--border); }
.section-num { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--accent); background: rgba(88,166,255,0.1); padding: 2px 8px; border-radius: 4px; font-weight: 600; letter-spacing: 0.5px; }
.section-title { font-size: 13px; font-weight: 600; color: var(--text); letter-spacing: 0.2px; text-transform: uppercase; }

/* Subsection divider */
.subsection-divider {
  background: rgba(88,166,255,0.05); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
  padding: 6px 20px; font-size: 11px; font-weight: 600; color: var(--accent);
  text-transform: uppercase; letter-spacing: 0.5px;
}

.rows { padding: 4px 0; }
.row { display: grid; grid-template-columns: 1fr 130px 120px 120px 90px; align-items: center; padding: 8px 20px; border-bottom: 1px solid rgba(48,54,61,0.5); gap: 8px; transition: background 0.15s; }
.row:last-child { border-bottom: none; }
.row:hover { background: rgba(255,255,255,0.02); }
.row-label { font-size: 13px; color: var(--text); font-weight: 400; }
.row-input input { width: 100%; background: var(--input-bg); border: 1px solid var(--border); border-radius: 6px; color: var(--accent); font-family: 'IBM Plex Mono', monospace; font-size: 13px; padding: 6px 10px; outline: none; transition: border-color 0.15s, box-shadow 0.15s; text-align: center; }
.row-input input:focus { border-color: var(--accent); box-shadow: 0 0 0 2px rgba(88,166,255,0.15); }
.row-norm { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--text3); text-align: center; }
.col-head { font-size: 10px; color: var(--text3); text-align: center; text-transform: uppercase; letter-spacing: 0.5px; }
.status { font-size: 18px; text-align: center; min-width: 28px; }
.row-patient input { color: var(--text); text-align: left; }
.row-auto .row-label { color: var(--text2); font-size: 12px; }
.calc-val { font-family: 'IBM Plex Mono', monospace; font-size: 13px; color: var(--text2); text-align: center; padding: 6px 10px; }
.col-headers { display: grid; grid-template-columns: 1fr 130px 120px 120px 90px; padding: 6px 20px; gap: 8px; background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--border); }
.conclusion-box { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.conclusion-header { background: linear-gradient(90deg, rgba(88,166,255,0.12), transparent); padding: 14px 20px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid var(--border); }
.conclusion-title { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
.conclusion-body { padding: 20px; }
#conclusion-text { font-family: 'IBM Plex Sans', sans-serif; font-size: 14px; line-height: 1.8; color: var(--text); white-space: pre-line; min-height: 80px; }
.conclusion-empty { color: var(--text3); font-style: italic; }
.btn-row { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
.btn { padding: 9px 18px; border-radius: 7px; font-size: 13px; font-weight: 500; cursor: pointer; border: none; font-family: 'IBM Plex Sans', sans-serif; transition: opacity 0.15s, transform 0.1s; }
.btn:active { transform: scale(0.97); }
.btn-primary { background: var(--accent); color: #0d1117; }
.btn-success { background: var(--normal); color: #0d1117; }
.btn-secondary { background: var(--surface2); color: var(--text); border: 1px solid var(--border); }
.btn:hover { opacity: 0.85; }
.btn-xs { padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 500; cursor: pointer; border: 1px solid var(--border); background: var(--surface); color: var(--text2); font-family: 'IBM Plex Sans', sans-serif; transition: all 0.15s; }
.btn-xs:hover { border-color: var(--accent); color: var(--accent); }
select { background: var(--input-bg); border: 1px solid var(--border); border-radius: 6px; color: var(--accent); font-family: 'IBM Plex Mono', monospace; font-size: 13px; padding: 6px 10px; outline: none; width: 100%; text-align: center; cursor: pointer; }
select:focus { border-color: var(--accent); box-shadow: 0 0 0 2px rgba(88,166,255,0.15); }
.badge-normal { color: var(--normal); }
.badge-abnormal { color: var(--abnormal); }
.badge-dash { color: var(--text3); }
.toast { position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 12px 20px; font-size: 14px; color: var(--text); opacity: 0; transition: all 0.3s; z-index: 999; white-space: nowrap; pointer-events: none; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
@media (max-width: 680px) {
  .col-headers { display: none; }
  .row { grid-template-columns: 1fr 100px 70px 70px 40px; padding: 8px 12px; }
  .hint { display: none; }
  .patients-bar { padding: 8px 16px; }
  .main { padding: 0 16px; margin: 20px auto; }
}
</style>
</head>
<body>
<header>
  <div class="logo">ЭхоКГ</div>
  <div>
    <h1>ЭхоКГ Калькулятор <span class="offline-badge" id="offline-badge">офлайн</span></h1>
    <span>Измерения и черновик заключения</span>
  </div>
  <div class="hint">
    <div class="hint-dot"><div class="dot" style="background:var(--accent)"></div>ввод</div>
    <div class="hint-dot"><div class="dot" style="background:var(--normal)"></div>норма</div>
    <div class="hint-dot"><div class="dot" style="background:var(--abnormal)"></div>отклонение</div>
  </div>
</header>

<div class="patients-bar">
  <span class="patients-bar-label">💾 Пациенты:</span>
  <div class="patients-list" id="patients-list"></div>
  <div class="patients-actions">
    <button class="btn-xs" onclick="saveCurrentPatient()">＋ Сохранить</button>
    <button class="btn-xs" onclick="newPatient()">✕ Новый</button>
  </div>
</div>

<div class="main">

  <!-- 01 Данные пациента -->
  <div class="section">
    <div class="section-header"><span class="section-num">01</span><span class="section-title">Данные пациента</span></div>
    <div class="col-headers">
      <div class="col-head">Параметр</div><div class="col-head">Значение</div>
      <div class="col-head" style="grid-column:3/5">—</div><div class="col-head">—</div>
    </div>
    <div class="rows">
      <div class="row row-patient">
        <div class="row-label">ФИО пациента</div>
        <div class="row-input" style="grid-column:2/5"><input type="text" id="fio" placeholder="Введите ФИО" oninput="recalc()"></div>
        <div></div>
      </div>
      <div class="row row-patient">
        <div class="row-label">Дата исследования</div>
        <div class="row-input"><input type="date" id="date" style="text-align:left;color:var(--text)" oninput="recalc()"></div>
        <div></div><div></div><div></div>
      </div>
      <div class="row">
        <div class="row-label">Пол</div>
        <div class="row-input">
          <select id="sex" onchange="recalc()"><option value="">—</option><option value="М">М</option><option value="Ж">Ж</option></select>
        </div>
        <div></div><div></div><div></div>
      </div>
      <div class="row">
        <div class="row-label">Возраст (лет)</div>
        <div class="row-input"><input type="number" id="age" placeholder="—" min="1" max="120" oninput="recalc()"></div>
        <div></div><div></div><div></div>
      </div>
      <div class="row">
        <div class="row-label">Рост (см)</div>
        <div class="row-input"><input type="number" id="height" placeholder="—" min="100" max="220" oninput="recalc()"></div>
        <div></div><div></div><div></div>
      </div>
      <div class="row">
        <div class="row-label">Вес (кг)</div>
        <div class="row-input"><input type="number" id="weight" placeholder="—" min="20" max="300" oninput="recalc()"></div>
        <div></div><div></div><div></div>
      </div>
      <div class="row row-auto">
        <div class="row-label">ППТ / BSA (м²) — Мостеллер</div>
        <div class="calc-val" id="bsa">—</div>
        <div class="row-norm">—</div><div class="row-norm">—</div>
        <div class="status badge-dash">—</div>
      </div>
    </div>
  </div>

  <!-- 02 Размеры камер -->
  <div class="section">
    <div class="section-header"><span class="section-num">02</span><span class="section-title">Размеры камер и стенок (M-режим / 2D PLAX)</span></div>
    <div class="col-headers"><div class="col-head">Параметр</div><div class="col-head">Значение</div><div class="col-head">Норма (жен)</div><div class="col-head">Норма (муж)</div><div class="col-head">Оценка</div></div>
    <div class="rows" id="section2"></div>
  </div>

  <!-- 03 Объёмы ЛЖ -->
  <div class="section">
    <div class="section-header"><span class="section-num">03</span><span class="section-title">Объёмы ЛЖ и фракция выброса (Симпсон)</span></div>
    <div class="col-headers"><div class="col-head">Параметр</div><div class="col-head">Значение</div><div class="col-head">Норма (жен)</div><div class="col-head">Норма (муж)</div><div class="col-head">Оценка</div></div>
    <div class="rows" id="section3"></div>
  </div>

  <!-- 04 Масса миокарда -->
  <div class="section">
    <div class="section-header"><span class="section-num">04</span><span class="section-title">Масса миокарда ЛЖ (формула ASE)</span></div>
    <div class="col-headers"><div class="col-head">Параметр</div><div class="col-head">Значение</div><div class="col-head">Норма (жен)</div><div class="col-head">Норма (муж)</div><div class="col-head">Оценка</div></div>
    <div class="rows" id="section4"></div>
  </div>

  <!-- 05 ЛП -->
  <div class="section">
    <div class="section-header"><span class="section-num">05</span><span class="section-title">Объём левого предсердия</span></div>
    <div class="col-headers"><div class="col-head">Параметр</div><div class="col-head">Значение</div><div class="col-head">Норма (жен)</div><div class="col-head">Норма (муж)</div><div class="col-head">Оценка</div></div>
    <div class="rows" id="section5"></div>
  </div>

  <!-- 06 Допплер + градиенты -->
  <div class="section">
    <div class="section-header"><span class="section-num">06</span><span class="section-title">Допплер — клапаны, градиенты и диастолическая функция</span></div>
    <div class="col-headers"><div class="col-head">Параметр</div><div class="col-head">Значение</div><div class="col-head">Норма (жен)</div><div class="col-head">Норма (муж)</div><div class="col-head">Оценка</div></div>
    <div class="rows" id="section6"></div>
  </div>

  <!-- 07 Правые отделы -->
  <div class="section">
    <div class="section-header"><span class="section-num">07</span><span class="section-title">Правые отделы</span></div>
    <div class="col-headers"><div class="col-head">Параметр</div><div class="col-head">Значение</div><div class="col-head">Норма (жен)</div><div class="col-head">Норма (муж)</div><div class="col-head">Оценка</div></div>
    <div class="rows" id="section7"></div>
  </div>

  <!-- 08 Перикард -->
  <div class="section">
    <div class="section-header"><span class="section-num">08</span><span class="section-title">Перикард</span></div>
    <div class="col-headers"><div class="col-head">Параметр</div><div class="col-head">Значение</div><div class="col-head">Норма (жен)</div><div class="col-head">Норма (муж)</div><div class="col-head">Оценка</div></div>
    <div class="rows" id="section8"></div>
  </div>

  <!-- 09 Заключение -->
  <div class="conclusion-box">
    <div class="conclusion-header"><span class="section-num">09</span><span class="conclusion-title">Автоматический черновик заключения</span></div>
    <div class="conclusion-body">
      <div id="conclusion-text" class="conclusion-empty">Заполните параметры выше для формирования заключения…</div>
      <div class="btn-row">
        <button class="btn btn-primary" onclick="copyConclusion()">📋 Копировать заключение</button>
        <button class="btn btn-success" onclick="saveCurrentPatient()">💾 Сохранить пациента</button>
        <button class="btn btn-secondary" onclick="clearAll()">🗑 Очистить всё</button>
      </div>
    </div>
  </div>

</div>
<div class="toast" id="toast"></div>

<script>
// =====================================================================
// ПАРАМЕТРЫ
// =====================================================================
const PARAMS = {
  s2: [
    { id:'lv_kdr',   label:'КДР ЛЖ (мм)',                        nf:'< 53',      nm:'< 59',      check:(v)=>[v<53,   v<59]   },
    { id:'lv_ksr',   label:'КСР ЛЖ (мм)',                        nf:'< 35',      nm:'< 40',      check:(v)=>[v<35,   v<40]   },
    { id:'mjp',      label:'МЖП диастола (мм)',                   nf:'6–9',       nm:'6–10',      check:(v)=>[v>=6&&v<=9, v>=6&&v<=10] },
    { id:'zslj',     label:'ЗСЛЖ диастола (мм)',                  nf:'6–9',       nm:'6–10',      check:(v)=>[v>=6&&v<=9, v>=6&&v<=10] },
    { id:'lp_plax',  label:'Левое предсердие PLAX (мм)',          nf:'< 38',      nm:'< 40',      check:(v)=>[v<38,   v<40]   },
    { id:'ao_plax',  label:'Аорта PLAX (мм)',                     nf:'< 36',      nm:'< 40',      check:(v)=>[v<36,   v<40]   },
    { id:'pj_plax',  label:'ПЖ PLAX — передне-задний (мм)',       nf:'≤ 30',      nm:'≤ 30',      check:(v)=>[v<=30,  v<=30]  },
    { id:'rvd1',     label:'RVD1 базальный ПЖ (апик., мм)',       nf:'≤ 41',      nm:'≤ 41',      check:(v)=>[v<=41,  v<=41]  },
    { id:'rwt',      label:'RWT — относит. толщина стенок',       nf:'0.32–0.42', nm:'0.32–0.42', check:(v)=>[v>=0.32&&v<=0.42, v>=0.32&&v<=0.42], step:'0.01' },
  ],
  s3: [
    { id:'kdo',  label:'КДО ЛЖ (мл) — Симпсон',  nf:'< 106', nm:'< 150', check:(v)=>[v<106, v<150] },
    { id:'kso',  label:'КСО ЛЖ (мл) — Симпсон',  nf:'< 42',  nm:'< 55',  check:(v)=>[v<42,  v<55]  },
    { id:'uo',   label:'УО (мл)',                  nf:'60–100',nm:'60–100',check:(v)=>[v>=60&&v<=100, v>=60&&v<=100], auto:true },
    { id:'fv',   label:'ФВ ЛЖ (%) — Симпсон',     nf:'≥ 55%', nm:'≥ 55%', check:(v)=>[v>=55, v>=55], auto:true },
  ],
  s4: [
    { id:'mmlj',  label:'ММЛЖ (г) — ASE',                    nf:'< 162 г',    nm:'< 224 г',    check:(v)=>[v<162,  v<224],  auto:true },
    { id:'immlj', label:'ИММЛЖ (г/м²) — индекс по ППТ',      nf:'< 95 г/м²',  nm:'< 115 г/м²', check:(v)=>[v<95,   v<115],  auto:true },
  ],
  s5: [
    { id:'lp_vol', label:'Объём ЛП (мл) — метод дисков / 2D', nf:'< 34', nm:'< 36', check:(v)=>[v<34, v<36] },
    { id:'lavi',   label:'ИОЛП / LAVI (мл/м²)',                nf:'< 28', nm:'< 28', check:(v)=>[v<28, v<28], auto:true },
  ],
  // Раздел 6: клапаны + диастолическая функция
  // Структура: обычные строки + специальные подгруппы с подзаголовком
  s6: [
    // --- Аортальный клапан ---
    { id:'vmax_ao',    label:'Аортальный: Vmax (м/с) — CW',           nf:'< 2.5', nm:'< 2.5', check:(v)=>[v<2.5,  v<2.5],  step:'0.01', group:'Аортальный клапан' },
    { id:'pg_max_ao',  label:'Аортальный: ΔP макс (мм рт.ст.) — авто',nf:'< 25',  nm:'< 25',  check:(v)=>[v<25,   v<25],   step:'0.1',  auto:true },
    { id:'pg_mean_ao', label:'Аортальный: ΔP средний (мм рт.ст.)',    nf:'< 13',  nm:'< 13',  check:(v)=>[v<13,   v<13],   step:'0.1'  },
    // --- Митральный клапан ---
    { id:'vmax_mv',    label:'Митральный: Vmax (м/с) — PW/CW',        nf:'< 1.3', nm:'< 1.3', check:(v)=>[v<1.3,  v<1.3],  step:'0.01', group:'Митральный клапан' },
    { id:'pg_max_mv',  label:'Митральный: ΔP макс (мм рт.ст.) — авто',nf:'< 7',   nm:'< 7',   check:(v)=>[v<7,    v<7],    step:'0.1',  auto:true },
    { id:'pg_mean_mv', label:'Митральный: ΔP средний (мм рт.ст.)',    nf:'< 5',   nm:'< 5',   check:(v)=>[v<5,    v<5],    step:'0.1'  },
    // --- Трикуспидальный клапан ---
    { id:'vmax_tv',    label:'Трикуспидальный: Vmax (м/с) — CW',      nf:'< 2.8', nm:'< 2.8', check:(v)=>[v<2.8,  v<2.8],  step:'0.01', group:'Трикуспидальный клапан' },
    { id:'pg_max_tv',  label:'Трикуспид.: ΔP макс (мм рт.ст.) — авто',nf:'< 31',  nm:'< 31',  check:(v)=>[v<31,   v<31],   step:'0.1',  auto:true },
    { id:'pg_mean_tv', label:'Трикуспид.: ΔP средний (мм рт.ст.)',    nf:'< 10',  nm:'< 10',  check:(v)=>[v<10,   v<10],   step:'0.1'  },
    // --- Лёгочный клапан ---
    { id:'vmax_pv',    label:'Лёгочный: Vmax (м/с) — CW',             nf:'< 1.5', nm:'< 1.5', check:(v)=>[v<1.5,  v<1.5],  step:'0.01', group:'Лёгочный клапан' },
    { id:'pg_max_pv',  label:'Лёгочный: ΔP макс (мм рт.ст.) — авто', nf:'< 9',   nm:'< 9',   check:(v)=>[v<9,    v<9],    step:'0.1',  auto:true },
    { id:'pg_mean_pv', label:'Лёгочный: ΔP средний (мм рт.ст.)',      nf:'< 6',   nm:'< 6',   check:(v)=>[v<6,    v<6],    step:'0.1'  },
    // --- Диастолическая функция ---
    { id:'mv_e',      label:'Митральный E (м/с) — PW',                 nf:'0.6–1.3',nm:'0.6–1.3',check:(v)=>[v>=0.6&&v<=1.3,v>=0.6&&v<=1.3],step:'0.01', group:'Диастолическая функция' },
