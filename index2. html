const TEXT_IDS = ['fio','date','sex','age','height','weight'];
const NUM_IDS = [
  ...PARAMS.s2.filter(p=>!p.auto&&!p.mirror).map(p=>p.id),
  ...PARAMS.s3.filter(p=>!p.auto).map(p=>p.id),
