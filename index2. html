// =====================================================================
// ПОСТРОЕНИЕ СЕКЦИЙ
// =====================================================================
function buildSection(secId, params) {
  const cont = document.getElementById(secId);
  let lastGroup = null;
  params.forEach(p => {
    // Подзаголовок группы
    if (p.group && p.group !== lastGroup) {
      lastGroup = p.group;
      const div = document.createElement('div');
      div.className = 'subsection-divider';
      div.textContent = p.group;
      cont.appendChild(div);
    }
    const row = document.createElement('div');
    row.className = 'row' + (p.auto ? ' row-auto' : '');

    let inputHtml;
    if (p.mirror) {
      // Зеркальное поле — только отображение, редактируется в другой секции
      inputHtml = `<div class="calc-val" id="val_${p.id}" style="color:var(--text3);font-size:12px">↑ из раздела 02</div>`;
    } else if (p.auto) {
      inputHtml = `<div class="calc-val" id="val_${p.id}">—</div>`;
    } else {
      inputHtml = `<input type="number" id="inp_${p.id}" step="${p.step||'1'}" placeholder="—" oninput="recalc()">`;
    }

    row.innerHTML = `
      <div class="row-label">${p.label}</div>
      <div class="row-input">${inputHtml}</div>
      <div class="row-norm">${p.nf}</div>
      <div class="row-norm">${p.nm}</div>
      <div class="status badge-dash" id="st_${p.id}">—</div>`;
    cont.appendChild(row);
  });
}

buildSection('section2', PARAMS.s2);
buildSection('section3', PARAMS.s3);
buildSection('section4', PARAMS.s4);
buildSection('section5', PARAMS.s5);
buildSection('section6', PARAMS.s6);
buildSection('section7', PARAMS.s7);
buildSection('section8', PARAMS.s8);

// =====================================================================
// УТИЛИТЫ
// =====================================================================
function getVal(id) {
  const el = document.getElementById('inp_' + id);
  if (!el) return null;
  const v = parseFloat(el.value);
  return isNaN(v) ? null : v;
}
function setCalc(id, val) {
  const el = document.getElementById('val_' + id);
  if (el) el.textContent = val !== null ? val : '—';
}
function setStatus(id, val, sex, checkFn) {
  const el = document.getElementById('st_' + id);
  if (!el) return;
  if (val === null) { el.textContent = '—'; el.className = 'status badge-dash'; return; }
  const ok = checkFn(val)[sex === 'М' ? 1 : 0];
  el.textContent = ok ? '✓' : '↑';
  el.className = 'status ' + (ok ? 'badge-normal' : 'badge-abnormal');
}
function fmt(v, dec=1) {
  if (v === null || isNaN(v)) return null;
  return parseFloat(v.toFixed(dec));
}
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// =====================================================================
// ПАЦИЕНТЫ
// =====================================================================
let currentPatientId = null;

function getPatients() { try { return JSON.parse(localStorage.getItem('echocg_patients') || '[]'); } catch { return []; } }
function savePatients(list) { localStorage.setItem('echocg_patients', JSON.stringify(list)); }

function collectFormData() {
  const d = {};
  TEXT_IDS.forEach(id => { const el = document.getElementById(id); if (el) d[id] = el.value; });
  NUM_IDS.forEach(id => { const el = document.getElementById('inp_' + id); if (el) d[id] = el.value; });
  return d;
}
function loadFormData(d) {
  TEXT_IDS.forEach(id => { const el = document.getElementById(id); if (el && d[id] !== undefined) el.value = d[id]; });
  NUM_IDS.forEach(id => { const el = document.getElementById('inp_' + id); if (el && d[id] !== undefined) el.value = d[id]; });
  recalc();
}
function saveCurrentPatient() {
  const fio  = document.getElementById('fio').value.trim();
  const date = document.getElementById('date').value;
  const name = fio || ('Пациент ' + new Date().toLocaleDateString('ru'));
  const label = date ? name + ' · ' + date : name;
  const patients = getPatients();
  const data = collectFormData();
  if (currentPatientId) {
    const idx = patients.findIndex(p => p.id === currentPatientId);
    if (idx !== -1) {
      patients[idx] = { id: currentPatientId, label, data };
      savePatients(patients); renderPatientsList();
      showToast('✓ Обновлено: ' + label); return;
    }
  }
  const id = Date.now().toString();
  currentPatientId = id;
  patients.push({ id, label, data });
  savePatients(patients); renderPatientsList();
  showToast('💾 Сохранено: ' + label);
}
function loadPatient(id) {
  const p = getPatients().find(x => x.id === id);
  if (!p) return;
  currentPatientId = id;
  loadFormData(p.data);
  renderPatientsList();
  showToast('📂 Загружен: ' + p.label);
}
function deletePatient(id, e) {
  e.stopPropagation();
  if (!confirm('Удалить пациента?')) return;
  savePatients(getPatients().filter(p => p.id !== id));
  if (currentPatientId === id) currentPatientId = null;
  renderPatientsList();
  showToast('🗑 Удалено');
}
function newPatient() {
  currentPatientId = null;
  document.querySelectorAll('input[type=number],input[type=text]').forEach(el => el.value = '');
  document.getElementById('sex').value = '';
  document.getElementById('date').value = new Date().toISOString().split('T')[0];
  recalc(); renderPatientsList();
  showToast('✕ Новый пациент');
}
function renderPatientsList() {
  const list = document.getElementById('patients-list');
  const patients = getPatients();
  if (!patients.length) {
    list.innerHTML = '<span style="font-size:12px;color:var(--text3);font-style:italic">Нет сохранённых</span>';
    return;
  }
  list.innerHTML = patients.map(p => `
    <div class="patient-chip${p.id === currentPatientId ? ' active' : ''}" onclick="loadPatient('${p.id}')">
      ${p.label}
      <span class="patient-chip-del" onclick="deletePatient('${p.id}',event)">×</span>
    </div>`).join('');
}

// =====================================================================
// ПЕРЕСЧЁТ
// =====================================================================
function recalc() {
  const sex = document.getElementById('sex').value;
  const H = parseFloat(document.getElementById('height').value);
  const W = parseFloat(document.getElementById('weight').value);

  // BSA
  let bsa = null;
  if (!isNaN(H) && !isNaN(W) && H > 0 && W > 0) bsa = fmt(Math.sqrt(H * W / 3600), 2);
  document.getElementById('bsa').textContent = bsa !== null ? bsa : '—';

  // --- Секция 02 ---
  PARAMS.s2.forEach(p => setStatus(p.id, getVal(p.id), sex, p.check));

  // --- Секция 03 ---
  const kdo = getVal('kdo'), kso = getVal('kso');
  let uo = null; if (kdo !== null && kso !== null) uo = fmt(kdo - kso, 0);
  setCalc('uo', uo); setStatus('uo', uo, sex, PARAMS.s3.find(p => p.id === 'uo').check);
  let fv = null; if (kdo !== null && kso !== null && kdo > 0) fv = fmt((kdo - kso) / kdo * 100, 1);
  setCalc('fv', fv); setStatus('fv', fv, sex, PARAMS.s3.find(p => p.id === 'fv').check);
  ['kdo','kso'].forEach(id => setStatus(id, getVal(id), sex, PARAMS.s3.find(x => x.id === id).check));

  // --- Секция 04 ---
  const kdr = getVal('lv_kdr'), mjp = getVal('mjp'), zslj = getVal('zslj');
  let mmlj = null;
  if (kdr !== null && mjp !== null && zslj !== null) {
    const a = kdr/10, b = mjp/10, cc = zslj/10;
    mmlj = fmt(0.8 * (1.04 * Math.pow(a+b+cc, 3) - Math.pow(a, 3)) + 0.6, 1);
  }
  setCalc('mmlj', mmlj !== null ? mmlj + ' г' : null);
  setStatus('mmlj', mmlj, sex, PARAMS.s4.find(p => p.id === 'mmlj').check);
  let immlj = null; if (mmlj !== null && bsa !== null && bsa > 0) immlj = fmt(mmlj / bsa, 1);
  setCalc('immlj', immlj !== null ? immlj + ' г/м²' : null);
  setStatus('immlj', immlj, sex, PARAMS.s4.find(p => p.id === 'immlj').check);

  // --- Секция 05 ---
  const lp_vol = getVal('lp_vol');
  setStatus('lp_vol', lp_vol, sex, PARAMS.s5.find(p => p.id === 'lp_vol').check);
  let lavi = null; if (lp_vol !== null && bsa !== null && bsa > 0) lavi = fmt(lp_vol / bsa, 1);
  setCalc('lavi', lavi !== null ? lavi + ' мл/м²' : null);
  setStatus('lavi', lavi, sex, PARAMS.s5.find(p => p.id === 'lavi').check);

  // --- Секция 06: градиенты и допплер ---
  // Аортальный
  const vmax_ao = getVal('vmax_ao');
  setStatus('vmax_ao', vmax_ao, sex, PARAMS.s6.find(p => p.id === 'vmax_ao').check);
  let pg_max_ao = null; if (vmax_ao !== null) pg_max_ao = fmt(4 * vmax_ao * vmax_ao, 1);
  setCalc('pg_max_ao', pg_max_ao !== null ? pg_max_ao + ' мм рт.ст.' : null);
  setStatus('pg_max_ao', pg_max_ao, sex, PARAMS.s6.find(p => p.id === 'pg_max_ao').check);
  setStatus('pg_mean_ao', getVal('pg_mean_ao'), sex, PARAMS.s6.find(p => p.id === 'pg_mean_ao').check);

  // Митральный (Vmax)
  const vmax_mv = getVal('vmax_mv');
  setStatus('vmax_mv', vmax_mv, sex, PARAMS.s6.find(p => p.id === 'vmax_mv').check);
  let pg_max_mv = null; if (vmax_mv !== null) pg_max_mv = fmt(4 * vmax_mv * vmax_mv, 1);
  setCalc('pg_max_mv', pg_max_mv !== null ? pg_max_mv + ' мм рт.ст.' : null);
  setStatus('pg_max_mv', pg_max_mv, sex, PARAMS.s6.find(p => p.id === 'pg_max_mv').check);
  setStatus('pg_mean_mv', getVal('pg_mean_mv'), sex, PARAMS.s6.find(p => p.id === 'pg_mean_mv').check);

  // Трикуспидальный
  const vmax_tv = getVal('vmax_tv');
  setStatus('vmax_tv', vmax_tv, sex, PARAMS.s6.find(p => p.id === 'vmax_tv').check);
  let pg_max_tv = null; if (vmax_tv !== null) pg_max_tv = fmt(4 * vmax_tv * vmax_tv, 1);
  setCalc('pg_max_tv', pg_max_tv !== null ? pg_max_tv + ' мм рт.ст.' : null);
  setStatus('pg_max_tv', pg_max_tv, sex, PARAMS.s6.find(p => p.id === 'pg_max_tv').check);
  setStatus('pg_mean_tv', getVal('pg_mean_tv'), sex, PARAMS.s6.find(p => p.id === 'pg_mean_tv').check);

  // Лёгочный
  const vmax_pv = getVal('vmax_pv');
  setStatus('vmax_pv', vmax_pv, sex, PARAMS.s6.find(p => p.id === 'vmax_pv').check);
  let pg_max_pv = null; if (vmax_pv !== null) pg_max_pv = fmt(4 * vmax_pv * vmax_pv, 1);
  setCalc('pg_max_pv', pg_max_pv !== null ? pg_max_pv + ' мм рт.ст.' : null);
  setStatus('pg_max_pv', pg_max_pv, sex, PARAMS.s6.find(p => p.id === 'pg_max_pv').check);
  setStatus('pg_mean_pv', getVal('pg_mean_pv'), sex, PARAMS.s6.find(p => p.id === 'pg_mean_pv').check);

  // Диастолическая функция
  const mv_e = getVal('mv_e'), mv_a = getVal('mv_a');
  const e_ps = getVal('e_prime_s'), e_pl = getVal('e_prime_l');
  ['mv_e','mv_a','e_prime_s','e_prime_l'].forEach(id => setStatus(id, getVal(id), sex, PARAMS.s6.find(p => p.id === id).check));
  let ea = null; if (mv_e !== null && mv_a !== null && mv_a > 0) ea = fmt(mv_e / mv_a, 2);
  setCalc('ea_ratio', ea); setStatus('ea_ratio', ea, sex, PARAMS.s6.find(p => p.id === 'ea_ratio').check);
  let epm = null; if (e_ps !== null && e_pl !== null) epm = fmt((e_ps + e_pl) / 2, 1);
  setCalc('e_prime_m', epm); setStatus('e_prime_m', epm, sex, PARAMS.s6.find(p => p.id === 'e_prime_m').check);
  let ee = null; if (mv_e !== null && epm !== null && epm > 0) ee = fmt(mv_e * 100 / epm, 2);
  setCalc('e_e_prime', ee); setStatus('e_e_prime', ee, sex, PARAMS.s6.find(p => p.id === 'e_e_prime').check);

  // --- Секция 07: зеркала из 02 + новые поля ---
  const pj_plax_val = getVal('pj_plax');
  const pjPlaxEl = document.getElementById('val_pj_plax_s7');
  if (pjPlaxEl) {
    pjPlaxEl.textContent = pj_plax_val !== null ? pj_plax_val + ' мм' : '↑ из раздела 02';
  }
  setStatus('pj_plax_s7', pj_plax_val, sex, PARAMS.s7.find(p => p.id === 'pj_plax_s7').check);

  const rvd1_val = getVal('rvd1');
  const rvd1El = document.getElementById('val_rvd1_s7');
  if (rvd1El) {
    rvd1El.textContent = rvd1_val !== null ? rvd1_val + ' мм' : '↑ из раздела 02';
  }
  setStatus('rvd1_s7', rvd1_val, sex, PARAMS.s7.find(p => p.id === 'rvd1_s7').check);

  ['rvd2','rvd3','tapse','sdla','ivc','ivc_col'].forEach(id => {
    const p = PARAMS.s7.find(x => x.id === id);
    if (p) setStatus(id, getVal(id), sex, p.check);
  });

  // --- Секция 08 ---
  PARAMS.s8.forEach(p => setStatus(p.id, getVal(p.id), sex, p.check));

  generateConclusion({ sex, bsa, kdr, kso, uo, fv, mmlj, immlj, lp_vol, lavi, ea, epm, ee,
    mv_e, mv_a, e_ps, e_pl, vmax_ao, pg_max_ao,
    vmax_mv, pg_max_mv, vmax_tv, pg_max_tv, vmax_pv, pg_max_pv });
}

// =====================================================================
// ЗАКЛЮЧЕНИЕ
// =====================================================================
function generateConclusion(c) {
  const fio   = document.getElementById('fio').value.trim();
  const dateEl = document.getElementById('date').value;
  const age   = parseFloat(document.getElementById('age').value);
  const sex   = c.sex;

  const allP = [...PARAMS.s2, ...PARAMS.s3, ...PARAMS.s5, ...PARAMS.s6, ...PARAMS.s7, ...PARAMS.s8];
  const hasData = allP.some(p => !p.auto && !p.mirror && getVal(p.id) !== null);
  if (!hasData) {
    const el = document.getElementById('conclusion-text');
    el.textContent = 'Заполните параметры выше для формирования заключения…';
    el.className = 'conclusion-empty'; return;
  }

  let lines = [];

  if (fio || dateEl || sex) {
    let h = 'Пациент:';
    if (fio) h += ' ' + fio;
    if (age && !isNaN(age)) h += ', ' + age + ' лет';
    if (sex) h += ', пол: ' + sex;
    if (dateEl) h += '. Дата: ' + dateEl;
    lines.push(h); lines.push('');
  }

  // ЛЖ
  const kdr = getVal('lv_kdr'), mjp = getVal('mjp'), zslj = getVal('zslj');
  const lim_kdr = sex === 'М' ? 59 : 53;
  if (kdr !== null) lines.push(kdr > lim_kdr
    ? `Левый желудочек расширен: КДР ${kdr} мм (норма < ${lim_kdr} мм).`
    : `Размеры левого желудочка в норме: КДР ${kdr} мм.`);
  if (mjp !== null || zslj !== null) {
    const limM = sex === 'М' ? 10 : 9;
    const mH = mjp !== null && mjp > limM, zH = zslj !== null && zslj > limM;
    lines.push(mH || zH
      ? `Гипертрофия стенок ЛЖ:${mH ? ' МЖП ' + mjp + ' мм' : ''}${zH ? ' ЗСЛЖ ' + zslj + ' мм' : ''}.`
      : 'Толщина стенок ЛЖ не увеличена.');
  }
  if (c.mmlj !== null) {
    const l = sex === 'М' ? 224 : 162;
    lines.push(c.mmlj > l
      ? `Масса миокарда ЛЖ увеличена: ММЛЖ ${c.mmlj} г (норма < ${l} г).`
      : `Масса миокарда ЛЖ в норме: ${c.mmlj} г.`);
  }
  if (c.fv !== null) lines.push(c.fv < 55
    ? `Снижение систолической функции ЛЖ: ФВ ${c.fv}% (норма ≥ 55%).`
    : `Систолическая функция ЛЖ сохранена: ФВ ${c.fv}%.`);

  // Диастолическая функция
  const dL = [];
  if (c.ea !== null) {
    if (c.ea < 0.8) dL.push(`E/A ${c.ea} (снижено, нарушение релаксации)`);
    else if (c.ea > 2.0) dL.push(`E/A ${c.ea} (рестриктивный тип)`);
  }
  if (c.ee !== null && c.ee >= 14) dL.push(`E/e' ${c.ee} (≥ 14, повышено давление наполнения)`);
  if (c.epm !== null && c.epm < 8.5) dL.push(`e' среднее ${c.epm} см/с (снижено)`);
  if (dL.length > 0) lines.push('Диастолическая функция: ' + dL.join('; ') + '.');
  else if (c.ea !== null || c.ee !== null) lines.push('Диастолическая функция не нарушена по доступным параметрам.');

  // ЛП / ЛАВИ
  const lp = getVal('lp_plax'), limLP = sex === 'М' ? 40 : 38;
  if (lp !== null) lines.push(lp > limLP
    ? `Левое предсердие расширено: ${lp} мм (PLAX).`
    : `Левое предсердие не расширено: ${lp} мм (PLAX).`);
  if (c.lavi !== null) lines.push(c.lavi > 28
    ? `LAVI ${c.lavi} мл/м² — увеличен.`
    : `LAVI ${c.lavi} мл/м² — норма.`);

  // Аорта
  const ao = getVal('ao_plax'), limAo = sex === 'М' ? 40 : 36;
  if (ao !== null) lines.push(ao > limAo
    ? `Корень аорты расширен: ${ao} мм.`
    : `Корень аорты не расширен: ${ao} мм.`);

  // Клапанные градиенты
  lines.push('');
  lines.push('Клапаны:');

  // Аортальный
  if (c.vmax_ao !== null) {
    const pg_mean_ao = getVal('pg_mean_ao');
    let s = `Аортальный клапан: Vmax ${c.vmax_ao} м/с, ΔP макс ${c.pg_max_ao} мм рт.ст.`;
    if (pg_mean_ao !== null) s += `, ΔP ср ${pg_mean_ao} мм рт.ст.`;
    if (c.vmax_ao >= 4.0)      s += ' — тяжёлый аортальный стеноз.';
    else if (c.vmax_ao >= 3.0) s += ' — умеренный аортальный стеноз.';
    else if (c.vmax_ao >= 2.5) s += ' — лёгкий аортальный стеноз.';
    else                        s += ' — скорость в норме.';
    lines.push(s);
  }

  // Митральный
  if (c.vmax_mv !== null) {
    const pg_mean_mv = getVal('pg_mean_mv');
    let s = `Митральный клапан: Vmax ${c.vmax_mv} м/с, ΔP макс ${c.pg_max_mv} мм рт.ст.`;
    if (pg_mean_mv !== null) s += `, ΔP ср ${pg_mean_mv} мм рт.ст.`;
    if (c.vmax_mv > 1.3) s += ' — признаки обструкции/стеноза МК.';
    else s += ' — скорость в норме.';
    lines.push(s);
  }

  // Трикуспидальный
  if (c.vmax_tv !== null) {
    const pg_mean_tv = getVal('pg_mean_tv');
    let s = `Трикуспидальный клапан: Vmax ${c.vmax_tv} м/с, ΔP макс ${c.pg_max_tv} мм рт.ст.`;
    if (pg_mean_tv !== null) s += `, ΔP ср ${pg_mean_tv} мм рт.ст.`;
    if (c.vmax_tv > 2.8) s += ' — повышенная скорость, возможна регургитация/стеноз.';
    else s += ' — скорость в норме.';
    lines.push(s);
  }

  // Лёгочный
  if (c.vmax_pv !== null) {
    const pg_mean_pv = getVal('pg_mean_pv');
    let s = `Лёгочный клапан: Vmax ${c.vmax_pv} м/с, ΔP макс ${c.pg_max_pv} мм рт.ст.`;
    if (pg_mean_pv !== null) s += `, ΔP ср ${pg_mean_pv} мм рт.ст.`;
    if (c.vmax_pv > 1.5) s += ' — повышенная скорость.';
    else s += ' — скорость в норме.';
    lines.push(s);
  }

  // Правые отделы
  lines.push('');
  const pj_plax_v = getVal('pj_plax');
  const rvd1_v = getVal('rvd1'), rvd2_v = getVal('rvd2'), rvd3_v = getVal('rvd3');
  const rvParts = [];
  if (pj_plax_v !== null) rvParts.push(`PLAX ${pj_plax_v} мм`);
  if (rvd1_v !== null) rvParts.push(`RVD1 ${rvd1_v} мм`);
  if (rvd2_v !== null) rvParts.push(`RVD2 ${rvd2_v} мм`);
  if (rvd3_v !== null) rvParts.push(`RVD3 (длина) ${rvd3_v} мм`);
  const rvDilated = (pj_plax_v !== null && pj_plax_v > 30) || (rvd1_v !== null && rvd1_v > 41) ||
                    (rvd2_v !== null && rvd2_v > 35) || (rvd3_v !== null && rvd3_v > 83);
  if (rvParts.length > 0) {
    lines.push(rvDilated
      ? `Правый желудочек расширен: ${rvParts.join(', ')}.`
      : `Размеры правого желудочка в норме: ${rvParts.join(', ')}.`);
  }

  const tapse = getVal('tapse');
  if (tapse !== null) lines.push(tapse < 17
    ? `Снижена систолическая функция правого желудочка: TAPSE ${tapse} мм.`
    : `Систолическая функция правого желудочка сохранена: TAPSE ${tapse} мм.`);

  const sdla = getVal('sdla');
  if (sdla !== null) lines.push(sdla >= 35
    ? `Лёгочная гипертензия: СДЛА ${sdla} мм рт.ст.`
    : `СДЛА в норме: ${sdla} мм рт.ст.`);

  const ivc = getVal('ivc'), ivc_col = getVal('ivc_col');
  if (ivc !== null) {
    let s = `НПВ ${ivc} мм`;
    if (ivc_col !== null) s += `, коллабирование ${ivc_col}%`;
    if (ivc > 21 && (ivc_col === null || ivc_col < 50)) s += ' — повышенное венозное давление';
    lines.push(s + '.');
  }

  // Перикард
  const peri = getVal('pericard');
  if (peri !== null) lines.push(peri >= 2
    ? `Выпот в полости перикарда: ${peri} мм.`
    : 'Перикард без особенностей.');

  const el = document.getElementById('conclusion-text');
  el.textContent = lines.join('\n'); el.className = '';
}

function copyConclusion() {
  const text = document.getElementById('conclusion-text').textContent;
  navigator.clipboard.writeText(text).then(() => showToast('✓ Заключение скопировано!'));
}

function clearAll() {
  if (!confirm('Очистить все введённые данные?')) return;
  currentPatientId = null;
  document.querySelectorAll('input[type=number],input[type=text]').forEach(el => el.value = '');
  document.getElementById('sex').value = '';
  document.getElementById('date').value = new Date().toISOString().split('T')[0];
  recalc(); renderPatientsList();
}

// =====================================================================
// ОФЛАЙН + ИНИТ
// =====================================================================
window.addEventListener('online',  () => document.getElementById('offline-badge').style.display = 'none');
window.addEventListener('offline', () => document.getElementById('offline-badge').style.display = 'inline-block');
if (!navigator.onLine) document.getElementById('offline-badge').style.display = 'inline-block';

document.getElementById('date').value = new Date().toISOString().split('T')[0];
renderPatientsList();
recalc();
</script>
</body>
</html>