    // Апикальная — 4-камерная
    { id:'rvd1_s7',    label:'RVD1 — базальный диаметр ПЖ (мм)',       nf:'≤ 41', nm:'≤ 41', check:(v)=>[v<=41,v<=41], group:'Апикальная 4-камерная позиция', mirror:'rvd1' },
    { id:'rvd2',       label:'RVD2 — средний диаметр ПЖ (мм)',         nf:'≤ 35', nm:'≤ 35', check:(v)=>[v<=35,v<=35] },
    { id:'rvd3',       label:'RVD3 — продольный размер ПЖ (мм)',       nf:'≤ 83', nm:'≤ 83', check:(v)=>[v<=83,v<=83] },
