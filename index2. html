    { id:'tapse',      label:'TAPSE (мм)',                              nf:'≥ 17', nm:'≥ 17', check:(v)=>[v>=17,v>=17], group:'Функция правого желудочка' },
    { id:'sdla',       label:'СДЛА (мм рт.ст.) — по TR',               nf:'< 35', nm:'< 35', check:(v)=>[v<35, v<35]  },
