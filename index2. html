    { id:'e_prime_s', label:"e' септальное TDI (см/с)",                nf:'≥ 7',   nm:'≥ 7',   check:(v)=>[v>=7,   v>=7],   step:'0.1'  },
    { id:'e_prime_l', label:"e' латеральное TDI (см/с)",               nf:'≥ 10',  nm:'≥ 10',  check:(v)=>[v>=10,  v>=10],  step:'0.1'  },
    { id:'e_prime_m', label:"e' среднее ((септ+лат)/2)",               nf:'≥ 8.5', nm:'≥ 8.5', check:(v)=>[v>=8.5, v>=8.5], step:'0.01',auto:true },
    { id:'e_e_prime', label:"E/e' среднее",                            nf:'< 14',  nm:'< 14',  check:(v)=>[v<14,   v<14],   step:'0.01',auto:true },
